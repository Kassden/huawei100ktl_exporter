# Local-first Raspberry Pi 4B deployment profile for SUN2000-100KTL-M2.
# Copy this file to .env.pi4b.local, fill in the real values locally,
# then rsync the repo to the Pi before running deploy/systemd/install-systemd.sh.

SUN2000_MODBUS_TRANSPORT=rtu
SUN2000_MODBUS_UNIT_ID=1
SUN2000_MODBUS_TIMEOUT=5.0

# On a Raspberry Pi 4B with a GPIO UART RS485 HAT, prefer /dev/serial0.
# Use /dev/ttyUSB0 only for a USB-to-RS485 adapter.
SUN2000_SERIAL_PORT=/dev/serial0
SUN2000_SERIAL_BAUDRATE=9600
SUN2000_SERIAL_PARITY=N
SUN2000_SERIAL_BYTESIZE=8
SUN2000_SERIAL_STOPBITS=1

# Optional TCP values kept for temporary simulator use
SUN2000_MODBUS_HOST=127.0.0.1
SUN2000_MODBUS_PORT=5020

HTTP_HOST=0.0.0.0
HTTP_PORT=8080

INFLUXDB_URL=https://your-influxdb-cloud-url:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org-name
INFLUXDB_BUCKET=solar-inverters
INFLUXDB_MEASUREMENT=huawei_sun2000
INFLUXDB_TIMEOUT=30

DEVICE_ID=sun2000_100ktl_m2_001
SITE_ID=site_001
COLLECTION_INTERVAL=60
BATCH_SIZE=10
RETRY_ATTEMPTS=3
RETRY_DELAY=5
EXPORTER_ENABLE_CONTROL=false
EXPORTER_STALE_AFTER_SECONDS=180
