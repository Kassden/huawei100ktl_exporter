# Recommended real inverter profile: RS485 / Modbus RTU
SUN2000_MODBUS_TRANSPORT=rtu
SUN2000_MODBUS_UNIT_ID=1
SUN2000_MODBUS_TIMEOUT=5.0
SUN2000_SERIAL_PORT=/dev/ttyUSB0
SUN2000_SERIAL_BAUDRATE=9600
SUN2000_SERIAL_PARITY=N
SUN2000_SERIAL_BYTESIZE=8
SUN2000_SERIAL_STOPBITS=1

# Optional TCP path for simulator or network Modbus
SUN2000_MODBUS_HOST=127.0.0.1
SUN2000_MODBUS_PORT=5020

# HTTP Server Configuration
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# InfluxDB Configuration
INFLUXDB_URL=https://your-influxdb-cloud-url:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org-name
INFLUXDB_BUCKET=solar-inverters
INFLUXDB_MEASUREMENT=huawei_sun2000
INFLUXDB_TIMEOUT=30

# Exporter Configuration
DEVICE_ID=sun2000_100ktl_m2_001
SITE_ID=site_001
COLLECTION_INTERVAL=60
BATCH_SIZE=10
RETRY_ATTEMPTS=3
RETRY_DELAY=5
EXPORTER_ENABLE_CONTROL=false
EXPORTER_STALE_AFTER_SECONDS=180

# Optional current ambient weather enrichment
# Open-Meteo current conditions are refreshed every 15 minutes by default.
WEATHER_ENABLED=false
WEATHER_PROVIDER=open_meteo
WEATHER_REFRESH_INTERVAL_SECONDS=900
WEATHER_MAX_STALE_SECONDS=3600
WEATHER_REQUEST_TIMEOUT_SECONDS=10
SITE_LATITUDE=22.275001
SITE_LONGITUDE=114.153326
SITE_TIMEZONE=Asia/Hong_Kong
